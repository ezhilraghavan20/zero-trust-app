{
    "compilerOptions": {
          "target": "ES6",
          "module": "commonjs",
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true,
          "forceConsistentCasingInFileNames": true,
          "outDir": "./dist",
          "rootDir": "./",
          "moduleResolution": "node"
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "module-12-frontend"]
}
